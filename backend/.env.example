# LLM provider: auto | openai | vercel | groq | gemini
# auto — Vercel AI Gateway if configured, otherwise OpenAI, Groq, then Gemini
LLM_PROVIDER=auto

# OpenAI Platform API — https://platform.openai.com/api-keys
# ChatGPT Plus billing is separate from API billing.
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Vercel AI Gateway — https://vercel.com/docs/ai-gateway
# AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key_here
# AI_GATEWAY_MODEL=openai/gpt-4o-mini
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Groq — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Auth token signing secret
MINDPATH_TOKEN_SECRET=change_this_secret_for_local_development
# MINDPATH_TOKEN_TTL_SECONDS=86400

# Backend config
# DATABASE_URL=sqlite+aiosqlite:///./app.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
